generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Salary {
  id             Int      @id @default(autoincrement())
  sirket         String
  pozisyon       String
  sektor         String
  sehir          String
  deneyimYil     Int
  maasAylik      Int
  bonusYillik    Int?
  calismaSekli   String
  egitimSeviyesi String
  olusturuldu    DateTime @default(now())
}
